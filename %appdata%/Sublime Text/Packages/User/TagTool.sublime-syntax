        (?xi)\b(
          ai |
          assets |
          cinematics |
          effects |
          fx |
          gfxt |
          globals |
          levels |
          multiplayer |
          objects |
          rasterizer |
          shaders |
          sound |
          ui |
          ms23 |
          ms30
        )\\
      scope: string.regexp.path.tagtool

    # ===================================================
