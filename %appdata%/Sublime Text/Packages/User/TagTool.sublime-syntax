---
name: TagTool
file_extensions:
  - cmds
scope: source.tagtool

contexts:
  main:
    # =============================
    #    Strings (Double Quoted)
    # =============================
    - match: '"'
      scope: punctuation.definition.string.begin.tagtool
      push: string

    # ==============
    #    Comments
    # ==============
    - match: '(?i)(?://|#|echo).*?$'
      scope: comment.line.tagtool

    # ===============
    #    Operators
    # ===============
    - match: '[>\.\*]'
      scope: keyword.operator.tagtool

    # ==============================
    #    Hex and Decimals Numbers
    # ==============================
    - match: '\b0x[0-9a-fA-F]+\b'
      scope: constant.numeric.hex.tagtool
    - match: '\b[0-9]+\b'
      scope: constant.numeric.decimal.tagtool

    # =============================
    #    Paths (Keywords Tier 4)
    # =============================
